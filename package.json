{
  "name": "operion-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Operion AI MVP v1 monorepo for AI-operated digital finance infrastructure.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @operion/dashboard run dev",
    "build": "npm --workspace @operion/shared run build && npm --workspace @operion/dashboard run build",
    "lint": "npm --workspace @operion/dashboard run lint",
    "typecheck": "npm --workspace @operion/shared run typecheck && npm --workspace @operion/dashboard run typecheck",
    "e2e:dashboard:login": "npm --workspace @operion/dashboard run e2e:login",
    "e2e:dashboard:login-persistence": "npm --workspace @operion/dashboard run e2e:login:persistence",
    "supabase:push": "node ./scripts/supabase-migrate.js push",
    "supabase:status": "node ./scripts/supabase-migrate.js status",
    "supabase:inspect": "node ./scripts/inspect-supabase-schema.mjs",
    "supabase:validate-schema": "node ./scripts/validate-production-schema.mjs",
    "supabase:apply": "node ./scripts/apply-migrations.js",
    "supabase:reconcile-ledger": "node ./scripts/reconcile-migration-ledger.mjs",
    "supabase:create-admin-user": "node ./scripts/create-admin-user.js",
    "supabase:create-admin-profile": "node ./scripts/create-admin-profile.js",
    "verify:deployment": "node ./scripts/verify-deployment.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
