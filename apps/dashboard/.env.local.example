# Local Supabase environment variables for apps/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-public-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Optional: keep these values in apps/dashboard/.env.local and do not commit the file.
# .env.local is ignored by the repository root gitignore.

# AI
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_MODEL_DEFAULT=claude-3-5-haiku
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6

# SendGrid
SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=verified@yourdomain.com
SENDGRID_FROM_NAME=Operion Capital
SENDGRID_WEBHOOK_PUBLIC_KEY=<your-sendgrid-event-webhook-public-key>

# Administrative settings
ADMIN_EMAIL=founder@yourdomain.com
CRON_SECRET=<your-vercel-cron-secret>
OPERION_INTERNAL_API_KEY=<your-internal-api-key>
SLACK_WEBHOOK_URL=
N8N_WEBHOOK_BASE_URL=

# Optional free-first acquisition sources. Use only founder-approved public URLs.
ACQUISITION_COMPANY_WEBSITE_URLS=
ACQUISITION_PUBLIC_DIRECTORY_URLS=
ACQUISITION_CHAMBER_DIRECTORY_URLS=
ACQUISITION_INDUSTRY_ASSOCIATION_URLS=
ACQUISITION_LOCAL_LISTING_URLS=
ACQUISITION_REQUEST_DELAY_MS=1000
ACQUISITION_MAX_URLS_PER_RUN=25
ACQUISITION_SCHEDULER_ENABLED=false
MERCHANT_INTELLIGENCE_SCHEDULER_ENABLED=false
