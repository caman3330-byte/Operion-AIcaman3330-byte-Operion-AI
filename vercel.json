{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm --workspace @operion/dashboard run build",
  "builds": [
    {
      "src": "apps/dashboard/package.json",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/outreach/workers/tick?limit=10&mode=lifecycle",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/workers/document-processing?limit=10",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/workers/lead-qualification?limit=10",
      "schedule": "15 10 * * *"
    },
    {
      "path": "/api/acquisition/merchant-sources/scheduler?limit=25&source_limit=5",
      "schedule": "45 10 * * *"
    },
    {
      "path": "/api/acquisition/merchant-intelligence/scheduler?limit=10",
      "schedule": "15 11 * * *"
    }
  ],
  "routes": [
    {
      "src": "^/(dashboard|application-status|settings)(/.*)?$",
      "status": 307,
      "headers": {
        "Location": "/thank-you?source=deprecated_merchant_portal"
      }
    },
    {
      "src": "^/(login|signin|signup|forgot-password|reset-password)$",
      "status": 307,
      "headers": {
        "Location": "/apply?source=merchant_auth_removed"
      }
    },
    {
      "src": "^/merchants/(.*)$",
      "status": 307,
      "headers": {
        "Location": "/apps/dashboard/merchants/$1"
      }
    },
    {
      "src": "^/(?!apps/dashboard)(.*)$",
      "dest": "/apps/dashboard/$1"
    }
  ]
}
