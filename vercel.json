{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm --workspace @operion/dashboard run build",
  "builds": [
    {
      "src": "apps/dashboard/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "^/(?!apps/dashboard)(.*)$",
      "dest": "/apps/dashboard/$1"
    }
  ]
}
